[Desktop Entry]
Version=1.1
Type=Application
Name=Przeglądarka internetowa
NoDisplay=true
Comment=Przegląda zawartość sieci internetowej
Icon=org.xfce.webbrowser
OnlyShowIn=XFCE;
Exec=exo-open --launch WebBrowser %u
Actions=
Categories=Network;X-XFCE;X-Xfce-Toplevel;
Keywords=internet;sieć;przeglądarka;surfowanie;eksplorowanie;xfce;
StartupNotify=true
