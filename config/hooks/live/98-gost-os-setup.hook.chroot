#!/bin/sh
set -e

echo ">>> Kopiowanie domyślnej konfiguracji użytkownika do /etc/skel..."
if [ -d "/konfiguracja" ]; then
    cp -rT /konfiguracja /etc/skel/
fi

echo ">>> Wyłączanie konfliktu z gnome-keyring..."
CONFLICT_FILE="/etc/xdg/autostart/gnome-keyring-secrets.desktop"
if [ -f "$CONFLICT_FILE" ]; then
    echo "Hidden=true" >> "$CONFLICT_FILE"
fi

exit 0