#!/bin/sh
# 'e' zatrzymuje skrypt w przypadku błędu
# 'x' włącza tryb debugowania dla TEGO skryptu
set -ex

echo ">>> Rozpoczynanie finalnej konfiguracji systemu (TRYB DEBUG)..."

# ------------------------------------------------------------------------------
# --- Krok 1: Instalacja motywów z katalogu /zasoby ---
# ------------------------------------------------------------------------------
echo ">>> Instalowanie motywów..."

if [ -d "/zasoby/WhiteSur-gtk-theme" ]; then
    echo "--> Instalowanie motywu WhiteSur GTK (z wymuszonym debugowaniem)..."
    sed -i 's/sudo //g' /zasoby/WhiteSur-gtk-theme/install.sh
    chmod +x /zasoby/WhiteSur-gtk-theme/install.sh
    # Uruchamiamy instalator przez 'bash -x', aby zobaczyć jego wewnętrzne komendy
    bash -x /zasoby/WhiteSur-gtk-theme/install.sh
else
    echo "--> Ostrzeżenie: Nie znaleziono instalatora motywu WhiteSur GTK w /zasoby/WhiteSur-gtk-theme."
fi

if [ -d "/zasoby/Win10Sur-icon-theme" ]; then
    echo "--> Instalowanie motywu ikon Win10Sur (z wymuszonym debugowaniem)..."
    sed -i 's/sudo //g' /zasoby/Win10Sur-icon-theme/install.sh
    chmod +x /zasoby/Win10Sur-icon-theme/install.sh
    # Uruchamiamy instalator przez 'bash -x', aby zobaczyć jego wewnętrzne komendy
    bash -x /zasoby/Win10Sur-icon-theme/install.sh
else
    echo "--> Ostrzeżenie: Nie znaleziono instalatora motywu ikon Win10Sur w /zasoby/Win10Sur-icon-theme."
fi

# ------------------------------------------------------------------------------
# --- Krok 2: Kopiowanie plików konfiguracyjnych ---
# ------------------------------------------------------------------------------
echo ">>> Kopiowanie domyślnej konfiguracji użytkownika..."

if [ -d "/konfiguracja" ]; then
    cp -rT /konfiguracja /etc/skel/
    echo "--> Konfiguracja skopiowana do /etc/skel."
else
    echo "--> Ostrzeżenie: Katalog /konfiguracja/ nie został znaleziony."
fi

# ------------------------------------------------------------------------------
# --- Krok 3: Czyszczenie ---
# ------------------------------------------------------------------------------
echo ">>> Czyszczenie plików tymczasowych..."
rm -rf /zasoby
rm -rf /konfiguracja
rm -rf /skrypty

echo ">>> Finalna konfiguracja systemu zakończona pomyślnie."